{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
        "allowJs": true,
        "noEmit": true
    },
    "extends": "./tsconfig.json",
    "include": [
        "src/**/*.ts",
        "tests/**/*.ts",
        "scripts/**/*.js",
        "tsup.config.ts",
        "vitest.config.ts",
        "eslint.config.js",
        "eslint.config.mjs",
        "benchmark.mjs",
        "profile-enhanced.mjs",
        "profile-parser.mjs",
        "plugin.mjs"
    ]
}
