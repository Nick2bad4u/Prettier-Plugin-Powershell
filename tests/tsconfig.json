        "declaration": false,
        "declarationMap": false,
        "isolatedDeclarations": false,
        "noEmit": true,
        "tsBuildInfoFile": "../.cache/tsbuildinfo/tsconfig.tests.tsbuildinfo"
    },
    "exclude": [
        "fixtures/**"
    ],
    "extends": "../tsconfig.json",
    "include": [
        "**/*.d.ts",
        "**/*.ts"
    ]
}
