{
    "name": "prettier-plugin-powershell",
    "$schema": "https://www.schemastore.org/package.json",
    "version": "2.0.11",
    "description": "Prettier plugin for formatting PowerShell source files with idiomatic defaults.",
    "keywords": [
        "prettier",
        "prettier-plugin",
        "powershell",
        "formatter",
        "formatting",
        "ps1",
        "psm1",
        "psd1",
        "pwsh",
        "scripting",
        "devtools",
        "code-formatting",
        "opinionated",
        "powershell-plugin"
    ],
    "homepage": "https://github.com/Nick2bad4u/prettier-plugin-powershell",
    "bugs": {
        "url": "https://github.com/Nick2bad4u/prettier-plugin-powershell/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nick2bad4u/prettier-plugin-powershell.git"
    },
    "license": "UnLicense",
    "type": "module",
    "files": [
        "dist"
    ],
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "scripts": {
        "build": "tsup src/index.ts --format esm,cjs --dts src/index.ts --dts-resolve --clean --sourcemap --tsconfig tsconfig.json --shims --treeshake safest --cjsInterop --metafile",
        "build:watch": "tsup src/index.ts --format esm,cjs --dts --watch",
        "clean": "rimraf dist",
        "lint": "eslint --config eslint.config.mjs src tests --cache --cache-strategy content --cache-location .cache/.eslintcache --max-warnings=-1 && echo \"Eslint done!\"",
        "lint:fix": "eslint --config eslint.config.mjs src tests --cache --cache-strategy content --cache-location .cache/.eslintcache --max-warnings=-1 --fix && echo \"Eslint done!\"",
        "format": "prettier \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" --write",
        "test": "vitest run",
        "test:fuzz": "pwsh -NoLogo -NoProfile -Command \"$env:POWERSHELL_PROPERTY_RUNS=2000; npm run test\"",
        "test:ci": "vitest run --reporter=summary",
        "test:debug": "vitest --inspect-brk",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "typecheck": "tsc --project tsconfig.json --noEmit",
        "benchmark": "node benchmark.mjs",
        "profile": "node profile-parser.mjs",
        "profile:enhanced": "node profile-enhanced.mjs",
        "prepare": "npm run build"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "@vitest/coverage-v8": "^4.1.4",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-array-func": "^5.1.1",
        "eslint-plugin-canonical": "^5.1.3",
        "eslint-plugin-case-police": "^2.2.1",
        "eslint-plugin-comment-length": "^2.3.0",
        "eslint-plugin-copilot": "^1.0.8",
        "eslint-plugin-css-modules": "^2.12.0",
        "eslint-plugin-de-morgan": "^2.1.1",
        "eslint-plugin-depend": "^1.5.0",
        "eslint-plugin-docusaurus-2": "^0.1.4",
        "eslint-plugin-eslint-plugin": "^7.3.2",
        "eslint-plugin-etc-misc": "^1.0.6",
        "eslint-plugin-file-progress-2": "^5.0.1",
        "eslint-plugin-github-actions-2": "^1.0.6",
        "eslint-plugin-immutable-2": "^1.0.9",
        "eslint-plugin-import": "^2.32.0",
        "fast-check": "^4.7.0",
        "prettier-plugin-ini": "^1.3.0",
        "prettier-plugin-interpolated-html-tags": "^2.0.1",
        "prettier-plugin-jsdoc": "^1.8.0",
        "prettier-plugin-merge": "^0.10.1",
        "prettier-plugin-multiline-arrays": "^4.1.5",
        "prettier-plugin-packagejson": "^3.0.2",
        "prettier-plugin-properties": "^0.3.1",
        "prettier-plugin-sort-json": "^4.2.0",
        "prettier-plugin-sql": "^0.20.0",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "typescript-eslint": "^8.58.2",
        "vitest": "^4.1.4"
    },
    "engines": {
        "node": ">=18.12.0"
    },
    "packageManager": "npm@11.12.1",
    "dependencies": {
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "tsup": "^8.5.1",
        "typescript": "^6.0.3"
    }
}
